Notebook[{

Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Torus", " ", "parameters"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"R", "=", "3"}], ";"}], "   ", 
   RowBox[{"(*", 
    RowBox[{"major", " ", "radius"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ";"}], "   ", 
   RowBox[{"(*", 
    RowBox[{"minor", " ", "radius"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"L", "=", "1"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Parametrization", " ", "of", " ", "torus"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"torus", "[", 
      RowBox[{"u_", ",", "v_"}], "]"}], ":=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"R", "+", 
          RowBox[{"r", " ", 
           RowBox[{"Cos", "[", "v", "]"}]}]}], ")"}], " ", 
        RowBox[{"Cos", "[", "u", "]"}]}], ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"R", "+", 
          RowBox[{"r", " ", 
           RowBox[{"Cos", "[", "v", "]"}]}]}], ")"}], " ", 
        RowBox[{"Sin", "[", "u", "]"}]}], ",", 
       RowBox[{"r", " ", 
        RowBox[{"Sin", "[", "v", "]"}]}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Tangent", " ", "vector", " ", "in", " ", "u"}], "-", 
     "direction"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Vu", "[", 
      RowBox[{"u_", ",", "v_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"torus", "[", 
         RowBox[{"uu", ",", "vv"}], "]"}], ",", "uu"}], "]"}], "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"uu", "->", "u"}], ",", 
        RowBox[{"vv", "->", "v"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Tangent", " ", "vector", " ", "in", " ", "v"}], "-", 
     "direction"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Vv", "[", 
      RowBox[{"u_", ",", "v_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"torus", "[", 
         RowBox[{"uu", ",", "vv"}], "]"}], ",", "vv"}], "]"}], "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"uu", "->", "u"}], ",", 
        RowBox[{"vv", "->", "v"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Sample", " ", "points", " ", "and", " ", "arrows"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"arrows", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"p", ",", "vec"}], "}"}], ",", 
         RowBox[{
          RowBox[{"p", "=", 
           RowBox[{"torus", "[", 
            RowBox[{"u", ",", "v"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"vec", "=", 
           RowBox[{"Normalize", "[", 
            RowBox[{
             RowBox[{"0.5", 
              RowBox[{"Vu", "[", 
               RowBox[{"u", ",", "v"}], "]"}]}], "+", " ", 
             RowBox[{"Vv", "[", 
              RowBox[{"u", ",", "v"}], "]"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Arrow", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"p", "-", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"L", "/", "2"}], ")"}], "vec"}]}], ",", 
             RowBox[{"p", "+", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"L", "/", "2"}], ")"}], " ", "vec"}]}]}], "}"}], 
           "]"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"u", ",", "0", ",", 
         RowBox[{
          RowBox[{"2", " ", "Pi"}], "-", 
          RowBox[{"2", " ", 
           RowBox[{"Pi", "/", "20"}]}]}], ",", 
         RowBox[{"2", " ", 
          RowBox[{"Pi", "/", "20"}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"v", ",", "0", ",", 
         RowBox[{
          RowBox[{"2", " ", "Pi"}], "-", 
          RowBox[{"2", " ", 
           RowBox[{"Pi", "/", "10"}]}]}], ",", 
         RowBox[{"2", " ", 
          RowBox[{"Pi", "/", "10"}]}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"ParametricPlot3D", "[", 
      RowBox[{
       RowBox[{"torus", "[", 
        RowBox[{"u", ",", "v"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"u", ",", "0", ",", 
         RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"v", ",", "0", ",", 
         RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
       RowBox[{"Mesh", "->", "None"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"Directive", "[", 
         RowBox[{
          RowBox[{"Opacity", "[", "0.6", "]"}], ",", "LightBlue"}], "]"}]}]}],
       "]"}], ",", 
     RowBox[{"Graphics3D", "[", 
      RowBox[{"{", 
       RowBox[{"Red", ",", 
        RowBox[{"Arrowheads", "[", "0.03", "]"}], ",", 
        RowBox[{"Flatten", "[", "arrows", "]"}]}], "}"}], "]"}], ",", 
     RowBox[{"Boxed", "->", "False"}], ",", 
     RowBox[{"Axes", "->", "False"}]}], "]"}]}]}]], "Input",
