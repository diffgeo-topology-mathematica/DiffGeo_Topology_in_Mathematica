          Offset[0.2], {
           Offset[0.4]}, 
          Offset[0.2]}}], "\[NoBreak]", ")"}],
    Function[BoxForm`e$, 
     MatrixForm[BoxForm`e$]]]}],
  SequenceForm["gdd = ", 
   MatrixForm[{{1, 0}, {0, Sin[$CellContext`\[Theta]]^2}}]],
  Editable->False]], "Print",
 CellChangeTimes->{3.889016659250046*^9, 3.8890174030126686`*^9, 
  3.8891849116287007`*^9, 3.919769127120014*^9, 3.9197705133643913`*^9, 
  3.919783489645587*^9, 3.964574042032544*^9},
 CellLabel->"During evaluation of In[4]:="],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"LineElement = \"\>", "\[InvisibleSpace]", 
   TagBox[
    RowBox[{
     SuperscriptBox[
      RowBox[{"d", "[", "r", "]"}], "2"], "+", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"d", "[", "\[Theta]", "]"}], "2"], " ", 
      SuperscriptBox[
       RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}],
    Short[#, 16]& ]}],
  SequenceForm["LineElement = ", 
   Short[$CellContext`d[$CellContext`r]^2 + $CellContext`d[$CellContext`\
\[Theta]]^2 Sin[$CellContext`\[Theta]]^2, 16]],
  Editable->False]], "Print",
 CellChangeTimes->{3.889016659250046*^9, 3.8890174030126686`*^9, 
  3.8891849116287007`*^9, 3.919769127120014*^9, 3.9197705133643913`*^9, 
  3.919783489645587*^9, 3.964574042034585*^9},
 CellLabel->"During evaluation of In[4]:="],

