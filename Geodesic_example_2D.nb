Cell["We begin by defining the coordinates and the metric:", "Text",
 CellChangeTimes->{{3.919769357977271*^9, 3.919769374011907*^9}, {
  3.964573987718045*^9, 3.9645739883578243`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Coordinates", " ", 
     RowBox[{"(", 
      RowBox[{"r", ",", "theta"}], ")"}], " ", "and", " ", "the", " ", 
     "metric", " ", "diag", 
     RowBox[{"(", 
      RowBox[{"1", ",", " ", 
       RowBox[{
        RowBox[{"sin", "^", "2"}], " ", "theta"}]}], ")"}]}], ";", " ", 
    RowBox[{
    "this", " ", "2", "D", " ", "metric", " ", "is", " ", "in", " ", "fact", 
     " ", "FLAT", " ", 
     RowBox[{"(", 
      RowBox[{"scalar", " ", "curvature", " ", "0"}], ")"}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"coordinates", "=", 
     RowBox[{"{", 
      RowBox[{"r", ",", " ", "\[Theta]"}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Metric", "=", 
     RowBox[{"DiagonalMatrix", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", 
        SuperscriptBox[
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], "}"}], "]"}]}], ";"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"n", "=", 
     RowBox[{"Length", "[", "coordinates", "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.889016564662817*^9, 3.8890166344400463`*^9}, {
  3.8890173772025833`*^9, 3.8890174000714397`*^9}, {3.919769089451931*^9, 
  3.9197690913279085`*^9}, {3.919770491471999*^9, 3.919770505808566*^9}, {
  3.919770847465234*^9, 3.9197708571008496`*^9}},
 CellLabel->"In[1]:="],

Cell["\<\
Apply the RGTC code to obtain the tensors that define the curvature:\
\>", "Text",
 CellChangeTimes->{{3.9197693791525087`*^9, 3.9197694077353673`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Compute", " ", "the", " ", "curvature", " ", "tensors"}], ";", 
     " ", 
     RowBox[{"the", " ", "curvature", " ", "vanishes"}]}], ",", " ", 
    RowBox[{"confirming", " ", "flat", " ", "space"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"RGtensors", "[", 
   RowBox[{"Metric", ",", " ", "coordinates"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.8890166384322977`*^9, 3.889016659006056*^9}},
 CellLabel->"In[4]:="],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"gdd = \"\>", "\[InvisibleSpace]", 
   TagBox[
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"1", "0"},
       {"0", 
        SuperscriptBox[
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}
      },
      GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
      GridBoxSpacings->{"Columns" -> {
          Offset[0.27999999999999997`], {
           Offset[0.7]}, 
