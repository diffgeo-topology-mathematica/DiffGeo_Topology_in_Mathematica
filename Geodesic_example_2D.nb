Cell["\<\
Let us now consider the coordinates as functions of an affine parameter \
\[Lambda]\
\>", "Text",
 CellChangeTimes->{{3.9197706691344357`*^9, 3.9197707047856445`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Coordinates", " ", "as", " ", "functions", " ", "of", " ", "an", " ", 
    "affine", " ", "parameter", " ", "lambda"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"CoordFunctions", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"r", "[", "\[Lambda]", "]"}], ",", " ", 
       RowBox[{"\[Theta]", "[", "\[Lambda]", "]"}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Mapping", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"coordinates", "[", 
        RowBox[{"[", "i", "]"}], "]"}], "->", 
       RowBox[{"CoordFunctions", "[", 
        RowBox[{"[", "i", "]"}], "]"}]}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"i", ",", "n"}], "}"}]}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.919770708582662*^9, 3.9197707284010468`*^9}, {
  3.9197707802936335`*^9, 3.919770783156931*^9}, {3.91977098268478*^9, 
  3.9197710106706395`*^9}},
 CellLabel->"In[5]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"r", "\[Rule]", 
    RowBox[{"r", "[", "\[Lambda]", "]"}]}], ",", 
   RowBox[{"\[Theta]", "\[Rule]", 
    RowBox[{"\[Theta]", "[", "\[Lambda]", "]"}]}]}], "}"}]], "Output",
 CellChangeTimes->{3.919771011608674*^9, 3.9197710674743876`*^9, 
  3.919783489688215*^9, 3.964574042058549*^9},
 CellLabel->"Out[6]="]
}, Open  ]],

Cell["\<\
To obtain the equation for a geodesic, we need to have the Christoffel symbols\
\>", "Text",
 CellChangeTimes->{{3.9197705304458303`*^9, 3.919770564119971*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"The", " ", "Christoffel", " ", "symbols", " ", 
    RowBox[{"Gamma", "^", "i_jk"}]}], "*)"}], "\[IndentingNewLine]", 
  "GUdd"}]], "Input",
 CellChangeTimes->{{3.9197705664867125`*^9, 3.9197706146468353`*^9}},
 CellLabel->"In[7]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0"}], "}"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"Cot", "[", "\[Theta]", "]"}]}], "}"}]}], "}"}]}], 
  "}"}]], "Output",
 CellChangeTimes->{{3.919770567673117*^9, 3.919770583256332*^9}, 
   3.9197706157015867`*^9, 3.9197707314772377`*^9, 3.919783489703974*^9, 
   3.964574042076891*^9},
 CellLabel->"Out[7]="]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Geodesic", " ", "equations", " ", "from", " ", "the", " ", "Christoffel", 
    " ", "symbols"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"GeodesicEqns", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"D", "[", " ", 
        RowBox[{
         RowBox[{"CoordFunctions", "[", 
          RowBox[{"[", "i", "]"}], "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"\[Lambda]", ",", " ", "2"}], "}"}]}], "]"}], "+", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"GUdd", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", " ", "j", ",", " ", "k"}], "]"}], "]"}], "/.",
             "Mapping"}], ")"}], 
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"CoordFunctions", "[", 
             RowBox[{"[", "j", "]"}], "]"}], ",", "\[Lambda]"}], "]"}], 
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"CoordFunctions", "[", 
             RowBox[{"[", "k", "]"}], "]"}], ",", " ", "\[Lambda]"}], "]"}]}],
          ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", " ", "n"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"k", ",", " ", "n"}], "}"}]}], "]"}]}], "==", "0"}], " ", 
     ",", " ", 
     RowBox[{"{", 
      RowBox[{"i", ",", " ", "n"}], "}"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9197706256537776`*^9, 3.919770659960559*^9}, {
  3.919770735552476*^9, 3.919770915513669*^9}, {3.9197709779195843`*^9, 
  3.9197709781233096`*^9}, {3.9197710160756025`*^9, 3.9197710780776844`*^9}, {
  3.9197834812378864`*^9, 3.9197834855182223`*^9}},
 CellLabel->"In[8]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{
     SuperscriptBox["r", "\[Prime]\[Prime]",
      MultilineFunction->None], "[", "\[Lambda]", "]"}], "\[Equal]", "0"}], 
   ",", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Cot", "[", 
       RowBox[{"\[Theta]", "[", "\[Lambda]", "]"}], "]"}], " ", 
      SuperscriptBox[
       RowBox[{
        SuperscriptBox["\[Theta]", "\[Prime]",
         MultilineFunction->None], "[", "\[Lambda]", "]"}], "2"]}], "+", 
     RowBox[{
      SuperscriptBox["\[Theta]", "\[Prime]\[Prime]",
       MultilineFunction->None], "[", "\[Lambda]", "]"}]}], "\[Equal]", 
    "0"}]}], "}"}]], "Output",
 CellChangeTimes->{{3.9197706502304325`*^9, 3.9197706603966866`*^9}, {
   3.9197707583364687`*^9, 3.919770791921111*^9}, {3.919770888429084*^9, 
   3.9197709160607386`*^9}, 3.9197710175578055`*^9, {3.919771058166957*^9, 
   3.9197710788930187`*^9}, 3.919783489716565*^9, 3.964574042095846*^9},
 CellLabel->"Out[8]="]
}, Open  ]]
