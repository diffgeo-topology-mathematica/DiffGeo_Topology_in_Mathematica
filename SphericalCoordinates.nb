(* Beginning of Notebook Content *)
Notebook[{
Cell["Spherical Coordinates", "Title",
 Evaluatable->False,
 CellHorizontalScrolling->False,
 CellChangeTimes->{{3.74719191158286*^9, 3.74719193148106*^9}, 
   3.7471969730106754`*^9, {3.7471974302084*^9, 3.7471974385648293`*^9}, {
   3.7472009691522083`*^9, 3.747200971234518*^9}},
 TextAlignment->Center],

Cell["\<\
This notebook shows how to use the package Difforms for calculating rotor, \
divergence and Laplace operators in curvilinear coordinates, here in \
spherical coordinates.\
\>", "Text",
 Evaluatable->False],

Cell["<< Loading the package\[LineSeparator]", "Section",
 Evaluatable->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Point", " ", "Mathematica", " ", "to", " ", "the", " ", "local", " ", 
    "Packages", " ", "folder", " ", "that", " ", "holds", " ", "Difform"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{"SetDirectory", "[", 
   RowBox[{
    RowBox[{"NotebookDirectory", "[", "]"}], "<>", "\"\</Packages/\>\""}], 
   "]"}]}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"0164a1a1-5b23-490a-99d2-b4f6a6e32afc"],

Cell[BoxData["\<\"/home/souvik/Documents/Mathematica with description/With \
description/Packages\"\>"], "Output",
 CellChangeTimes->{3.993514890650333*^9, 3.993515967361106*^9},
 CellLabel->"Out[1]=",ExpressionUUID->"9005c0ea-9570-40db-bb6a-42353c073ebf"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Load", " ", "the", " ", "Difform", " ", "package"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"<<", "Difform`"}]}]], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"28763fd0-510d-4989-b2d0-62d788272b8f"],

Cell[BoxData[""], "Input",
 PageWidth:>Infinity,
 CellLabel->"In[3]:=",ExpressionUUID->"f49a7d9b-e908-4bf6-865b-dc8e1b7f2255"],

Cell["Defining the Metric", "Section",
 Evaluatable->False],

Cell["\<\
We will work with spherical coordinates (r, \[Theta], \[Phi]), consisting of \
oblate rotational ellipsoids (\[Xi] = const.), rotational hyperboloids (\
\[Theta] = const.), and axial planes as coordinate surfaces (\[Phi] = \
const.). The connection to Cartesian coordinates (x,y,z) is given by x = r \
sin(\[Theta]) cos(\[Phi]), y = r sin(\[Theta]) sin(\[Phi]) and z = r cos(\
\[Theta]).\
\>", "Text",
 Evaluatable->False,
 CellChangeTimes->{{3.7471920363059797`*^9, 3.747192053625436*^9}, {
   3.7471975559635444`*^9, 3.747197591900062*^9}, {3.747197659679597*^9, 
   3.7471977204857597`*^9}, {3.74719785465983*^9, 3.7471978968399935`*^9}, {
   3.7471979480141554`*^9, 3.7471979553122516`*^9}, 3.7471984212884035`*^9, {
   3.7471985163581486`*^9, 3.747198536523757*^9}, {3.7471986785380363`*^9, 
   3.7471987810158668`*^9}, 3.7472000672625437`*^9, {3.7472009875884504`*^9, 
   3.747200990836299*^9}, {3.747204863952114*^9, 3.747204889795745*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Plot", " ", "the", " ", "spheres", " ", "r"}], " ", "=", " ", 
    RowBox[{"const", " ", "as", " ", "coordinate", " ", "surfaces"}]}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{"Show", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"ParametricPlot3D", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"r", " ", 
           RowBox[{"Sin", "[", "\[Theta]", "]"}], 
           RowBox[{"Cos", "[", "\[Phi]", "]"}]}], ",", 
          RowBox[{"r", " ", 
           RowBox[{"Sin", "[", "\[Theta]", "]"}], 
           RowBox[{"Sin", "[", "\[Phi]", "]"}]}], ",", 
          RowBox[{"r", " ", 
           RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Theta]", ",", "0", ",", "\[Pi]"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Phi]", ",", "0", ",", "\[Pi]"}], "}"}], ",", 
        RowBox[{"PlotStyle", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"Opacity", "[", 
           RowBox[{"1", "-", 
            RowBox[{"0.4", " ", "r"}]}], "]"}], "}"}]}], ",", 
        RowBox[{"MeshStyle", "\[Rule]", "Gray"}], ",", 
        RowBox[{"PlotPoints", "\[Rule]", "50"}], ",", 
        RowBox[{"ImageSize", "\[Rule]", "400"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", "0.2", ",", "1", ",", "0.2"}], "}"}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
    RowBox[{"Axes", "\[Rule]", "None"}], ",", 
    RowBox[{"Boxed", "\[Rule]", "False"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.5600597498904324`*^9, 3.5600601867660666`*^9}, {
   3.5600602397771435`*^9, 3.5600602979752283`*^9}, {3.5600603450122967`*^9, 
