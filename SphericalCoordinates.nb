Cell[TextData[{
 "Let us first find the line element ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["ds", "2"], TraditionalForm]]]
}], "Text",
 CellChangeTimes->{3.7472000563987694`*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "First", " ", "set", " ", "a", " ", "trivial", " ", "Cartesian", " ", 
     "basis", " ", "and", " ", "metric"}], ",", " ", 
    RowBox[{
    "to", " ", "read", " ", "off", " ", "the", " ", "line", " ", "element", 
     " ", "from", " ", "the", " ", "embedding"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Coord", "=", 
     RowBox[{"{", 
      RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Basis", "=", 
     RowBox[{"DiagonalMatrix", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", "1", ",", "1"}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Metric", "=", 
     RowBox[{"DiagonalMatrix", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", "1", ",", "1"}], "}"}], "]"}]}], ";"}]}]}]], "Input",\

 CellChangeTimes->{{3.7471978996601114`*^9, 3.7471980203532953`*^9}, 
   3.747198519970195*^9, 3.747204920266535*^9},
 CellLabel->"In[6]:=",ExpressionUUID->"31efb238-5cfe-4c89-a42a-e034b1c2e769"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Line", " ", "element", " ", 
     RowBox[{"ds", "^", "2"}]}], " ", "=", " ", 
    RowBox[{
     RowBox[{"dr", "^", "2"}], " ", "+", " ", 
     RowBox[{
      RowBox[{"r", "^", "2"}], " ", "d", " ", 
      RowBox[{"theta", "^", "2"}]}], " ", "+", " ", 
     RowBox[{
      RowBox[{"r", "^", "2"}], " ", 
      RowBox[{"sin", "^", "2"}], " ", "theta", " ", "d", " ", 
      RowBox[{"phi", "^", "2"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Expand", "[", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"Diff", "[", 
       RowBox[{"r", " ", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}], 
        RowBox[{"Cos", "[", "\[Phi]", "]"}]}], "]"}], "2"], "+", 
     SuperscriptBox[
      RowBox[{"Diff", "[", 
       RowBox[{"r", " ", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}], 
        RowBox[{"Sin", "[", "\[Phi]", "]"}]}], "]"}], "2"], "+", 
     SuperscriptBox[
      RowBox[{"Diff", "[", 
       RowBox[{"r", " ", 
        RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "]"}], "2"]}], "]"}], "//", 
   "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.7471980329518766`*^9, 3.747198057126237*^9}, 
   3.7471985651831956`*^9, {3.74719861800753*^9, 3.7471986551844916`*^9}, {
   3.747199721996006*^9, 3.74719973389557*^9}, {3.7472049279326787`*^9, 
   3.7472049455973988`*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"2274ddf6-c529-46fb-b40f-847988835a36"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox[
   RowBox[{"Diff", "[", "r", "]"}], "2"], "+", 
  RowBox[{
   SuperscriptBox["r", "2"], " ", 
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"Diff", "[", "\[Theta]", "]"}], "2"], "+", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"Diff", "[", "\[Phi]", "]"}], "2"], " ", 
      SuperscriptBox[
       RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}], ")"}]}]}]], "Output",
 CellChangeTimes->{{3.7471980447882385`*^9, 3.747198058078632*^9}, {
   3.74719856645901*^9, 3.74719859217964*^9}, {3.7471986447120504`*^9, 
   3.7471986561588078`*^9}, {3.747199724946552*^9, 3.7471997354781885`*^9}, 
   3.747204947018242*^9, 3.993514897449461*^9, 3.993515973296657*^9},
 CellLabel->"Out[9]=",ExpressionUUID->"982c937c-bfbd-4dbf-8ed3-28fcc0059a7c"]
}, Open  ]],

Cell["Now, we can define the correct basis 1-forms: ", "Text",
 CellChangeTimes->{{3.7471987938320923`*^9, 3.7471988206482744`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Now", " ", "set", " ", "the", " ", "proper", " ", "orthonormal", " ", 
     RowBox[{"coframe", ":", " ", "dr"}]}], ",", " ", 
    RowBox[{"r", " ", "d", " ", "theta"}], ",", " ", 
    RowBox[{"r", " ", "sin", " ", "theta", " ", "d", " ", "phi"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Coord", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"r", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], "}"}]}], ";"}],
    " ", "\n", 
   RowBox[{
    RowBox[{"Basis", " ", "=", " ", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "0", ",", " ", "0"}], "}"}], ",", " ", "\n", 
       "   ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "r", ",", " ", "0"}], "}"}], ",", " ", "\n", 
       "   ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "0", ",", " ", 
         RowBox[{"r", " ", 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], "}"}]}], 
      "\[IndentingNewLine]", "}"}]}], ";"}], " ", "\n", 
   RowBox[{
    RowBox[{"Metric", " ", "=", " ", 
     RowBox[{"DiagonalMatrix", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "1", ",", " ", "1"}], "}"}], "]"}]}], ";"}], 
   " "}]}]], "Input",
 PageWidth:>Infinity,
 CellChangeTimes->{{3.747198868222819*^9, 3.747199008938321*^9}, {
   3.747199799298257*^9, 3.747199858314458*^9}, 3.7471999398745375`*^9, {
   3.747200666001342*^9, 3.7472006850789967`*^9}, {3.747200815649657*^9, 
   3.7472008288845043`*^9}, {3.747204958409685*^9, 3.7472049833840575`*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"bb2c80f5-faaf-4350-a2ef-df788c068bc0"],

Cell["\<\
Next, we create the inverse basis, inverse metric tensor and other auxiliary \
functions by\
\>", "Text",
 Evaluatable->False,
 CellChangeTimes->{{3.747192287597496*^9, 3.7471923922019978`*^9}, {
   3.747196988378621*^9, 3.7471970054946723`*^9}, 3.747199044062476*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Build", " ", "the", " ", "Riemannian", " ", "metric", " ", "space"}], 
    ",", " ", 
    RowBox[{
     RowBox[{"signature", " ", "+", "1"}], ":", " ", 
     RowBox[{"inverse", " ", "basis"}]}], ",", " ", 
    RowBox[{
    "inverse", " ", "metric", " ", "and", " ", "auxiliary", " ", 
     "functions"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"MakeMetricSpace", "[", "1", "]"}], ";"}]}]], "Input",
 CellChangeTimes->{{3.7472007033488665`*^9, 3.7472007092957983`*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"af312b43-c636-4d23-89b2-5c52b0123e51"],

Cell["Divergence And Rotor", "Section",
 Evaluatable->False,
 CellChangeTimes->{{3.7471990949012527`*^9, 3.747199096901554*^9}, {
  3.7471993409243493`*^9, 3.747199345721016*^9}}],

Cell["Define a 1-form:", "Text",
 Evaluatable->False,
 CellChangeTimes->{{3.7471924077801476`*^9, 3.747192408747568*^9}, {
  3.7471991000859947`*^9, 3.747199108433672*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"A", " ", "general", " ", "1"}], "-", 
     RowBox[{"form", " ", "v"}]}], " ", "=", " ", 
    RowBox[{
     RowBox[{"vr", " ", "dr"}], " ", "+", " ", 
     RowBox[{"vtheta", " ", "d", " ", "theta"}], " ", "+", " ", 
     RowBox[{"vphi", " ", "d", " ", "phi"}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"v", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"vr", "[", 
      RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], 
     RowBox[{"Diff", "[", "r", "]"}]}], "+", 
    RowBox[{
     RowBox[{"v\[Theta]", "[", 
      RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], 
     RowBox[{"Diff", "[", "\[Theta]", "]"}]}], "+", 
    RowBox[{
     RowBox[{"v\[Phi]", "[", 
      RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], 
     RowBox[{"Diff", "[", "\[Phi]", "]"}]}]}]}]}]], "Input",
 CellChangeTimes->{{3.747199135860241*^9, 3.747199210230476*^9}, {
  3.7472049920262938`*^9, 3.74720500344407*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"04bd5ab8-05a6-4e91-8c3e-5778737d05be"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Diff", "[", "r", "]"}], " ", 
   RowBox[{"vr", "[", 
    RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], "+", 
  RowBox[{
   RowBox[{"Diff", "[", "\[Theta]", "]"}], " ", 
   RowBox[{"v\[Theta]", "[", 
    RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], "+", 
  RowBox[{
   RowBox[{"Diff", "[", "\[Phi]", "]"}], " ", 
   RowBox[{"v\[Phi]", "[", 
    RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}]}]], "Output",
 CellChangeTimes->{{3.747199187013714*^9, 3.7471992111237745`*^9}, 
   3.747199905564384*^9, 3.7472008346312957`*^9, 3.747205006954364*^9, 
   3.993514897484284*^9, 3.993515973354926*^9},
 CellLabel->"Out[14]=",ExpressionUUID->"f1101afe-7a8e-48f3-8f8d-01ce2e140a67"]
}, Open  ]],

Cell["Divergence", "Text",
 CellChangeTimes->{{3.7471992308475075`*^9, 3.7471992351527767`*^9}}],

Cell[CellGroupData[{

Cell["divv = Hodge[Diff[Hodge[v]]]//FullSimplify", "Input",
 PageWidth:>Infinity,
 CellChangeTimes->{{3.747192422580838*^9, 3.747192425363266*^9}, {
  3.747197037909198*^9, 3.747197062617393*^9}, {3.747199114178955*^9, 
  3.7471991311634398`*^9}, {3.7471992268634725`*^9, 3.7471992774234314`*^9}, {
  3.7472003301085057`*^9, 3.7472003329887037`*^9}},
 FontFamily->"Courier New",
 FontSize->12,
 FontWeight->"Bold",
 FontColor->GrayLevel[0],
 Background->GrayLevel[1],
 CellLabel->"In[15]:=",ExpressionUUID->"7caeced3-40c3-48b8-9637-b3fc3241614c"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{
    RowBox[{"2", " ", "r", " ", 
     RowBox[{"vr", "[", 
      RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], "+", 
    RowBox[{
     RowBox[{"Cot", "[", "\[Theta]", "]"}], " ", 
     RowBox[{"v\[Theta]", "[", 
      RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], "+", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"Csc", "[", "\[Theta]", "]"}], "2"], " ", 
     RowBox[{
      SuperscriptBox["v\[Phi]", 
       TagBox[
        RowBox[{"(", 
         RowBox[{"0", ",", "0", ",", "1"}], ")"}],
