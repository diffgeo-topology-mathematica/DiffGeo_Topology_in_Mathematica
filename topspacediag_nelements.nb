Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{
  "This", " ", "notebook", " ", "illustrates", " ", "the", " ", "topological",
    " ", "space", " ", "diagram", " ", "pictorially"}], ",", " ", 
  RowBox[{
   RowBox[{"for", " ", "an", " ", "n"}], "-", 
   RowBox[{"element", " ", "set", " ", 
    RowBox[{"(", 
     RowBox[{
     "It", " ", "also", " ", "tells", " ", "us", " ", "which", " ", "ones", " ",
       "are", " ", "good", " ", "topologies", " ", "and", " ", "which", " ", 
      "ones", " ", "are", " ", "bad", " ", "topologies"}], 
     ")"}]}]}]}]], "Input",ExpressionUUID->"a6086c6f-8e7b-48bf-8422-\
03cf2860bd42"],

Cell[BoxData[
 RowBox[{
  RowBox[{"topologyQ", "[", "x_List", "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Intersection", "[", 
      RowBox[{"x", ",", "#"}], "]"}], "===", "#"}], "&"}], "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Union", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Union", "@@", "x"}], "}"}], ",", 
       RowBox[{"Intersection", "@@@", 
        RowBox[{"Rest", "@", "#"}]}], ",", 
       RowBox[{"Union", "@@@", "#"}]}], "]"}], "&"}], "@", 
    RowBox[{"Subsets", "@", "x"}]}], "]"}]}]], "Input",
 CellLabel->"In[9]:=",ExpressionUUID->"1ebb6f03-7334-49d4-aee2-d048cc903b01"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"RandomTopoTable", "[", "n_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Sets", "=", 
         RowBox[{"Reverse", "[", 
          RowBox[{"Sort", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"RandomSample", "[", 
              RowBox[{"#", ",", 
               RowBox[{"RandomChoice", "[", 
                RowBox[{"Range", "[", 
                 RowBox[{"Length", "[", "#", "]"}], "]"}], "]"}]}], "]"}], 
             "&"}], "[", 
            RowBox[{"Subsets", "[", 
             RowBox[{"Range", "[", "n", "]"}], "]"}], "]"}], "]"}], "]"}]}], ",", 
        RowBox[{"GenerateRow", "=", 
         RowBox[{"Function", "[", 
          RowBox[{
           RowBox[{"{", "set", "}"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"#", ",", 
               RowBox[{"Background", "->", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"MemberQ", "[", 
                   RowBox[{"set", ",", "#"}], "]"}], ",", "Red", ",", 
                  "White"}], "]"}]}], ",", 
               RowBox[{"Frame", "->", "True"}]}], "}"}], "&"}], "/@", 
            RowBox[{"Range", "[", "n", "]"}]}]}], "]"}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"topologyQ", "[", "Sets", "]"}], "&&", 
           RowBox[{"MemberQ", "[", 
            RowBox[{"Sets", ",", 
             RowBox[{"Range", "[", "n", "]"}]}], "]"}]}], ",", 
          RowBox[{"Style", "[", 
           RowBox[{"\"\<GOOD\>\"", ",", 
            RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
          RowBox[{"Style", "[", 
           RowBox[{"\"\<BAD\>\"", ",", "Red"}], "]"}]}], "]"}], ",", 
        RowBox[{"Grid", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"Range", "[", "n", "]"}], "}"}], "~", "Join", "~", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"Item", "@@@", "#"}], "&"}], ")"}], "/@", 
              RowBox[{"(", 
               RowBox[{"GenerateRow", "/@", "Sets"}], ")"}]}], ")"}]}], ")"}],
           ",", 
          RowBox[{"Frame", "->", "All"}], ",", 
          RowBox[{"Background", "->", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Lighter", "[", "Gray", "]"}], ",", "None"}], "}"}]}]}], 
         "]"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"Column", "[", 
    RowBox[{"RandomTopoTable", "[", "3", "]"}], "]"}], ",", 
   RowBox[{"{", "20", "}"}]}], "]"}]}], "Input",
 CellLabel->"In[12]:=",ExpressionUUID->"b79324af-7008-4dc2-ad9b-896219d78939"],

