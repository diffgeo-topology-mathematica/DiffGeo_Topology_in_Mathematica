   "ObjectType" -> "Symbol", "Usage" -> 
    "Orientation[metric] calculates a unit length generator of the top \t\
dimensional exterior algebra on the variables contained in metric.  \tIt \
assumes that the orientation is consistent with the orientation \ton the \
variable produced by the Sort function.\t\n\nExamples:\n\nOrientation[t[x,x] \
+ t[y,y]]\t\n\nOrientation[t[r,r] + r^2 t[theta, theta] + t[z,z]].", 
    "Documentation" -> None, "OwnValues" -> None, "UpValues" -> None, 
    "DownValues" -> 
    Information`InformationValueForm[
     DownValues, DifferentialForms`Orientation, {DifferentialForms`Orientation[
         Pattern[C, 
          Blank[DifferentialForms`Chain]]] :> First[C], 
       DifferentialForms`Orientation[
         Pattern[DifferentialForms`Private`metric, 
          Blank[]], 
         Pattern[DifferentialForms`Private`opt, 
          BlankNullSequence[]]] :> 
       Block[{DifferentialForms`Private`vars, DifferentialForms`Private`omega,
           DifferentialForms`Private`dot, DifferentialForms`Private`g = 
          DifferentialForms`Simple[DifferentialForms`Private`metric]}, 
         DifferentialForms`Private`vars = Union[
            Cases[
            DifferentialForms`Private`g, DifferentialForms`Private`form[
               Blank[], {
                Pattern[DifferentialForms`Private`x, 
                 BlankSequence[]]}] -> DifferentialForms`Private`x]]; 
         DifferentialForms`Private`omega = 
          Apply[DifferentialForms`ExteriorProduct, 
            Map[DifferentialForms`d[#]& , DifferentialForms`Private`vars]]; 
         DifferentialForms`Private`dot = 
          DifferentialForms`InnerProduct[
           DifferentialForms`Private`omega, DifferentialForms`Private`omega, 
            DifferentialForms`Private`g]; 
         DifferentialForms`Private`riemannian = ReplaceAll[
            ReplaceAll[
            DifferentialForms`Riemannian, {DifferentialForms`Private`opt}], 
            Options[DifferentialForms`Orientation]]; 
         If[DifferentialForms`Private`riemannian, 
           DifferentialForms`Private`omega/Sqrt[
           DifferentialForms`Private`dot], (Sqrt[
              Abs[DifferentialForms`Private`dot]]/
            DifferentialForms`Private`dot) 
           DifferentialForms`Private`omega]]}], "SubValues" -> None, 
    "DefaultValues" -> None, "NValues" -> None, "FormatValues" -> None, 
    "Options" -> {DifferentialForms`Riemannian -> True}, "Attributes" -> {}, 
    "FullName" -> "DifferentialForms`Orientation"], False]]], "Output",
