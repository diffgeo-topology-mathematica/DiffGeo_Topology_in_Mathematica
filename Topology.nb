Cell[CellGroupData[{

Cell["Connectedness", "Section",
 CellChangeTimes->{{3.961638626480097*^9, 
  3.961638630200035*^9}},ExpressionUUID->"ae3752bc-3dcb-4440-91ac-\
21f74f5a23eb"],

Cell["\<\
Let S = {1,2,3}, with the topology U = {{}, {1}, {2,3}, {1,2,3}}\
\>", "Text",
 CellChangeTimes->{{3.961639306199665*^9, 
  3.9616393324908247`*^9}},ExpressionUUID->"38e14f03-ebf8-4b71-b21d-\
e3699c40e2e6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"S", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"U", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", "}"}], ",", 
     RowBox[{"{", "1", "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"IsTopologyQ", "[", 
  RowBox[{"S", ",", " ", "U"}], "]"}]}], "Input",
 CellChangeTimes->{{3.9616394587682858`*^9, 3.961639470827726*^9}},
 CellLabel->"In[77]:=",ExpressionUUID->"51f91c64-8dd3-4364-8377-06771f80d7e9"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.961639471347883*^9},
 CellLabel->"Out[79]=",ExpressionUUID->"e7ed34da-faaf-4367-9cb1-b5c71f7399fa"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"IsConnectedQ", "[", 
   RowBox[{"set_", ",", "subsets_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"s", ",", "test"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"s", " ", "=", " ", 
      RowBox[{"Subsets", "[", 
       RowBox[{
        RowBox[{"Complement", "[", 
         RowBox[{"subsets", ",", 
          RowBox[{"{", 
           RowBox[{"set", ",", " ", 
            RowBox[{"{", "}"}]}], "}"}]}], "]"}], ",", 
        RowBox[{"{", "2", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"test", " ", "=", 
      RowBox[{"And", "@@", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"And", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Union", "@@", "i"}], "===", "set"}], ",", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"Intersection", "@@", "i"}], ")"}], "===", 
              RowBox[{"{", "}"}]}]}], "]"}], ",", "True", ",", "False"}], 
          "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "s"}], "}"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"test", " ", "===", "True"}], ",", " ", 
       RowBox[{"Print", "[", "\"\<disconnected\>\"", "]"}], ",", 
       RowBox[{"Print", "[", "\"\<connected\>\"", "]"}]}], "]"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.961639480191532*^9, 3.9616394814297457`*^9}, {
  3.961639678896098*^9, 3.961639752561377*^9}, {3.96163988397011*^9, 
  3.961639955218779*^9}, {3.961639987738895*^9, 3.961640139604413*^9}, {
  3.961640205324692*^9, 3.961640262005368*^9}, {3.9616403252057657`*^9, 
  3.96164033048641*^9}, {3.9616405207366943`*^9, 3.9616405230796537`*^9}},
 CellLabel->
  "In[128]:=",ExpressionUUID->"7a33e0af-4102-4927-bd6e-b14c5f0aaf72"],

Cell["\<\
Let us consider U1 ={{},{1},{2,3},{1,2,3}}. Expect {} and S, the other two \
subsets of U1 are {1} and {2,3}.
We observe that Intersection[{1},{2,3}] = {} and Union[{1},{2,3}] = S. Thus, \
the topology is disconnected\
\>", "Text",
 CellChangeTimes->{{3.96164037665298*^9, 
  3.961640471142798*^9}},ExpressionUUID->"a1467393-7c8d-4939-a7fe-\
cd46c6cbb6ac"],

