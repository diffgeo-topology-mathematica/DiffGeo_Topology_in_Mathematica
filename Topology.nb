Cell[TextData[{
 StyleBox["Advanced Mathematica problem",
  Background->RGBColor[1, 1, 0.85]],
 " :\[LineSeparator]\[LineSeparator]Given a discrete set S and subsets T, \
write a Mathematica module to check if T is a topology on S.\n\n\nSolution : \
Test with other examples"
}], "Text",
 CellChangeTimes->{{3.9162741025939083`*^9, 3.916274192683893*^9}, {
  3.9162751126607904`*^9, 3.9162751192368703`*^9}, {3.9162755185338917`*^9, 
  3.9162755241723413`*^9}},ExpressionUUID->"4da0d531-2cc2-4b50-a4fd-\
8c7b328ba860"],

Cell[BoxData[
 RowBox[{
  RowBox[{"IsTopologyQ", "[", 
   RowBox[{"set_", ",", "subsets_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "test", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"SubsetQ", "[", 
        RowBox[{"set", ",", 
         RowBox[{"DeleteDuplicates", "[", 
          RowBox[{"Flatten", "[", "subsets", "]"}], "]"}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"test", " ", "=", 
         RowBox[{"Sort", "[", 
          RowBox[{"DeleteDuplicates", "[", 
           RowBox[{"Union", "/@", 
            RowBox[{"Flatten", "/@", 
             RowBox[{"Subsets", "[", "subsets", "]"}]}]}], "]"}], "]"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"Return", "[", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"test", "===", 
            RowBox[{"Sort", "[", "subsets", "]"}]}], ",", "True", ",", 
           "False"}], "]"}], "]"}], ";"}], "\[IndentingNewLine]", ",", 
       RowBox[{"Return", "[", "False", "]"}]}], "]"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.9162742998678775`*^9, 3.916274462586247*^9}, {
   3.9162745121918726`*^9, 3.9162745164808426`*^9}, {3.916274555747094*^9, 
   3.9162745625093946`*^9}, {3.9162750003942895`*^9, 3.916275108592399*^9}, {
   3.9162751707712965`*^9, 3.9162753707582493`*^9}, 3.916275543816105*^9},
 CellLabel->"In[7]:=",ExpressionUUID->"0a3bc2ec-d254-4b95-a0e1-d0460f56f961"],

