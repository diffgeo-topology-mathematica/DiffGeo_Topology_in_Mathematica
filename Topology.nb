  RowBox[{"S", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", "}"}], ",", 
     RowBox[{"{", "1", "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.961639744097287*^9, 3.961639784448214*^9}, {
   3.961639869810462*^9, 3.961639871169551*^9}, {3.961639961883615*^9, 
   3.9616399684764633`*^9}, {3.9616400420287*^9, 3.961640050955206*^9}, 
