Cell["The geodesic equations are given by", "Text",
 CellChangeTimes->{{3.964570856635038*^9, 3.9645708621228313`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Geodesic", " ", "equations", " ", "from", " ", "the", " ", "Christoffel", 
    " ", "symbols"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"GeodesicEqns", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"D", "[", " ", 
        RowBox[{
         RowBox[{"CoordFunctions", "[", 
          RowBox[{"[", "i", "]"}], "]"}], ",", " ", 
         RowBox[{"{", 
