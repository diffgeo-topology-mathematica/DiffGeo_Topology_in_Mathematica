Cell["\<\
We begin by defining the coordinates and the metric in Schwarzschild \
spacetime:\
\>", "Text",
 CellChangeTimes->{{3.919769357977271*^9, 3.919769374011907*^9}, {
  3.964570744178005*^9, 3.96457074874614*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Coordinates", " ", 
    RowBox[{"(", 
     RowBox[{"t", ",", "r", ",", "theta", ",", "phi"}], ")"}], " ", "and", 
    " ", "the", " ", "Schwarzschild", " ", "metric", " ", "with", " ", "mass",
     " ", "M"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"coordinates", "=", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "r", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], 
      "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Metric", "=", 
     RowBox[{"DiagonalMatrix", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"2", "G", " ", 
            RowBox[{"M", "/", "r"}]}]}], ")"}]}], ",", " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"2", "G", " ", 
            RowBox[{"M", "/", "r"}]}]}], ")"}], 
         RowBox[{"-", "1"}]], ",", " ", 
        SuperscriptBox["r", "2"], ",", " ", 
        RowBox[{
         SuperscriptBox["r", "2"], 
         SuperscriptBox[
          RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}], "}"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"n", " ", "=", " ", 
     RowBox[{"Length", "[", "coordinates", "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.889016564662817*^9, 3.8890166344400463`*^9}, {
  3.8890173772025833`*^9, 3.8890174000714397`*^9}, {3.919769089451931*^9, 
  3.9197690913279085`*^9}, {3.919770491471999*^9, 3.919770505808566*^9}, {
