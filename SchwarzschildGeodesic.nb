    "affine", " ", "parameter", " ", "lambda"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"CoordFunctions", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"t", "[", "\[Lambda]", "]"}], ",", " ", 
       RowBox[{"r", "[", "\[Lambda]", "]"}], ",", " ", 
