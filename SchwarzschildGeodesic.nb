       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"GUdd", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", " ", "j", ",", " ", "k"}], "]"}], "]"}], "/.",
             "Mapping"}], ")"}], " ", 
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"CoordFunctions", "[", 
             RowBox[{"[", "j", "]"}], "]"}], ",", " ", "\[Lambda]"}], "]"}], 
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"CoordFunctions", "[", 
             RowBox[{"[", "k", "]"}], "]"}], ",", " ", "\[Lambda]"}], "]"}]}],
          ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", " ", "n"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"k", ",", " ", "n"}], "}"}]}], "]"}]}], "==", "0"}], " ", 
     ",", " ", 
     RowBox[{"{", 
      RowBox[{"i", ",", " ", "n"}], "}"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9197706256537776`*^9, 3.919770659960559*^9}, {
   3.919770735552476*^9, 3.919770915513669*^9}, {3.9197709779195843`*^9, 
