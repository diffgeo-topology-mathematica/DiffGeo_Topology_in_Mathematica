Cell["One specific geodesic equation that lies on \
\[Theta][\[Lambda]]==\[Pi]/2 ", "Text",
 CellChangeTimes->{{3.964570880379211*^9, 3.9645708970688343`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Equatorial", " ", 
     RowBox[{"geodesics", ":", " ", 
      RowBox[{"set", " ", "theta"}]}]}], " ", "=", " ", 
    RowBox[{
     RowBox[{"pi", "/", "2"}], " ", "and", " ", "simplify"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"Assuming", "[", 
   RowBox[{
    RowBox[{"{", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Theta]", "[", "\[Lambda]", "]"}], "==", 
       RowBox[{"\[Pi]", "/", "2"}]}], ",", "  ", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Theta]", "'"}], "[", "\[Lambda]", "]"}], "==", "0"}], ",", 
      "  ", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Theta]", "''"}], "[", "\[Lambda]", "]"}], "==", "0"}]}], 
     "}"}], ",", " ", 
    RowBox[{"GeodesicEqns", "//", "FullSimplify"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9197835144196825`*^9, 3.9197836143595495`*^9}},
 CellLabel->"In[25]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{
     SuperscriptBox["t", "\[Prime]\[Prime]",
      MultilineFunction->None], "[", "\[Lambda]", "]"}], "\[Equal]", 
