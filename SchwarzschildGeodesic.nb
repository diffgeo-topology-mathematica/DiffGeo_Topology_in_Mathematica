   3.9197710780776844`*^9}, {3.9197832257376547`*^9, 3.9197832452730227`*^9}, 
   3.919783300890134*^9, {3.9197834678739333`*^9, 3.919783471870925*^9}},
 CellLabel->"In[23]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"-", 
