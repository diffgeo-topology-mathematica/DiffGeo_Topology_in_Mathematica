Cell["\<\
We begin by defining the coordinates and the metric of the unit 2-sphere:\
\>", "Text",
 CellChangeTimes->{{3.919769357977271*^9, 3.919769374011907*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Coordinates", " ", 
      RowBox[{"(", 
       RowBox[{"theta", ",", "phi"}], ")"}], " ", "and", " ", "the", " ", 
      "round", " ", "unit", " ", "2"}], "-", 
     RowBox[{"sphere", " ", "metric", " ", 
      RowBox[{"ds", "^", "2"}]}]}], " ", "=", " ", 
    RowBox[{
     RowBox[{"dtheta", "^", "2"}], " ", "+", " ", 
     RowBox[{
      RowBox[{"sin", "^", "2"}], " ", "theta", " ", 
      RowBox[{"dphi", "^", "2"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"coordinates", "=", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", " ", "\[Phi]"}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Metric", "=", 
     RowBox[{"DiagonalMatrix", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", 
        SuperscriptBox[
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], "}"}], "]"}]}], ";"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"n", "=", 
     RowBox[{"Length", "[", "coordinates", "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.889016564662817*^9, 3.8890166344400463`*^9}, {
   3.8890173772025833`*^9, 3.8890174000714397`*^9}, {3.919769089451931*^9, 
   3.9197690913279085`*^9}, {3.919770491471999*^9, 3.919770505808566*^9}, {
