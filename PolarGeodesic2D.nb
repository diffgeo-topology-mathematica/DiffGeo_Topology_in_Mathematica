Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Geodesic", " ", "equations"}], ";", " ", 
    RowBox[{
    "their", " ", "solutions", " ", "are", " ", "the", " ", "great", " ", 
     "circles", " ", "of", " ", "the", " ", "sphere"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"GeodesicEqns", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"D", "[", " ", 
        RowBox[{
         RowBox[{"CoordFunctions", "[", 
          RowBox[{"[", "i", "]"}], "]"}], ",", " ", 
         RowBox[{"{", 
