Cell["\<\
Let us now consider the coordinates as functions of an affine parameter \
\[Lambda]\
\>", "Text",
 CellChangeTimes->{{3.9197706691344357`*^9, 3.9197707047856445`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Treat", " ", "the", " ", "coordinates", " ", "as", " ", "functions", " ", 
    "of", " ", "an", " ", "affine", " ", "parameter", " ", "lambda"}], "*)"}],
   "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"CoordFunctions", "=", 
     RowBox[{"{", " ", 
      RowBox[{
       RowBox[{"\[Theta]", "[", "\[Lambda]", "]"}], ",", 
       RowBox[{"\[Phi]", "[", "\[Lambda]", "]"}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Mapping", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"coordinates", "[", 
        RowBox[{"[", "i", "]"}], "]"}], "->", 
       RowBox[{"CoordFunctions", "[", 
        RowBox[{"[", "i", "]"}], "]"}]}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"i", ",", "n"}], "}"}]}], "]"}]}]}]}]], "Input",
