 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{"\[CapitalLambda]", "+", 
     RowBox[{"\[Kappa]", " ", "\[Rho]"}]}], ")"}], " ", 
   SuperscriptBox[
    RowBox[{"a", "[", "t", "]"}], "2"]}], "\[Equal]", 
  RowBox[{"3", " ", 
   RowBox[{"(", 
    RowBox[{"k", "+", 
