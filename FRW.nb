Cell["\<\
In this notebook, we use the RGTC code to find the Christoffel symbols and \
other tensors\
\>", "Text",
 CellChangeTimes->{{3.964560445177473*^9, 3.964560446345035*^9}, {
  3.964560481809507*^9, 3.964560544690577*^9}}],

Cell["Let us define the coordinate and the metric first.", "Text",
 CellChangeTimes->{{3.964560551442018*^9, 3.964560565034397*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Coordinates", " ", 
    RowBox[{"(", 
     RowBox[{"t", ",", "r", ",", "theta", ",", "phi"}], ")"}], " ", "and", 
    " ", "the", " ", "FRW", " ", "metric", " ", "with", " ", "scale", " ", 
    "factor", " ", 
    RowBox[{"a", "[", "t", "]"}], " ", "and", " ", "spatial", " ", 
    "curvature", " ", "k"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"coordinates", "=", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "r", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], 
      "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Metric", "=", 
     RowBox[{"DiagonalMatrix", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", " ", 
        FractionBox[
         SuperscriptBox[
          RowBox[{"a", "[", "t", "]"}], "2"], 
         RowBox[{"1", "-", 
          RowBox[{"k", " ", 
           SuperscriptBox["r", "2"]}]}]], ",", " ", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"a", "[", "t", "]"}], "2"], 
         SuperscriptBox["r", "2"]}], ",", " ", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"a", "[", "t", "]"}], "2"], 
         SuperscriptBox["r", "2"], 
         SuperscriptBox[
          RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}], "}"}], "]"}]}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.889016564662817*^9, 3.8890166344400463`*^9}, {
  3.8890173772025833`*^9, 3.8890174000714397`*^9}, {3.919769089451931*^9, 
  3.9197690913279085`*^9}, {3.964560584540873*^9, 3.9645605911559267`*^9}},
 CellLabel->"In[1]:="],

Cell["\<\
Apply the RGTC code to obtain the tensors that define the curvature:\
\>", "Text",
 CellChangeTimes->{{3.9197693791525087`*^9, 3.9197694077353673`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
