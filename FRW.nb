Cell["\<\
As we can see, the spacetime is conformally flat.  Now we want to obtain the \
Friedmann equations. So first define the stress-energy tensor for a perfect \
fluid:\
\>", "Text",
 CellChangeTimes->{{3.91976941236158*^9, 3.9197694614166713`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Perfect", "-", 
    RowBox[{"fluid", " ", "stress"}], "-", 
    RowBox[{
    "energy", " ", "tensor", " ", "with", " ", "density", " ", "rho", " ", 
     "and", " ", "pressure", " ", "p"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Tdd", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Rho]", "+", "p"}], ")"}], " ", 
       RowBox[{"DiagonalMatrix", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}], "]"}]}], "+", 
      RowBox[{"p", " ", "gdd"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Tdd", "//", "MatrixForm"}]}]}]], "Input",
 CellChangeTimes->{{3.889016662489442*^9, 3.8890168389124203`*^9}, {
