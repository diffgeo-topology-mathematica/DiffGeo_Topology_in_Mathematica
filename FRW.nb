    RowBox[{
     RowBox[{"Einstein", " ", "equation", " ", "residual", " ", "R_ij"}], " ",
      "-", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "2"}], ")"}], " ", "R", " ", "g_ij"}], " ", "+", " ", 
     RowBox[{"Lambda", " ", "g_ij"}], " ", "-", " ", 
     RowBox[{"kappa", " ", "T_ij"}]}], ",", " ", 
    RowBox[{"to", " ", "be", " ", "set", " ", "to", " ", "zero"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Zerodd", "=", 
    RowBox[{"Rdd", "-", 
     RowBox[{
      FractionBox["1", "2"], "R", " ", "gdd"}], " ", "+", " ", 
     RowBox[{"\[CapitalLambda]", " ", "gdd"}], "-", 
     RowBox[{"\[Kappa]", " ", "Tdd"}]}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.8890169654816294`*^9, 3.8890169923515234`*^9}, {
  3.8890172409222684`*^9, 3.889017305407292*^9}},
 CellLabel->"In[22]:="],

Cell["Note that, the off - diagonal elements are already zero", "Text",
 CellChangeTimes->{{3.964562179256907*^9, 3.964562185477891*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"The", " ", "diagonal", " ", "Einstein", " ", "equations"}], ",", 
    " ", 
    RowBox[{"fully", " ", "simplified"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Diagonal", "[", "Zerodd", "]"}], "//", 
   "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.9645621112164793`*^9, 3.964562113406108*^9}, {
  3.96456216096821*^9, 3.964562166903736*^9}},
 CellLabel->"In[38]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"-", "\[CapitalLambda]"}], "-", 
    RowBox[{"\[Kappa]", " ", "\[Rho]"}], "+", 
    FractionBox[
     RowBox[{"3", " ", 
      RowBox[{"(", 
       RowBox[{"k", "+", 
        SuperscriptBox[
         RowBox[{
          SuperscriptBox["a", "\[Prime]",
           MultilineFunction->None], "[", "t", "]"}], "2"]}], ")"}]}], 
     SuperscriptBox[
      RowBox[{"a", "[", "t", "]"}], "2"]]}], ",", 
   FractionBox[
    RowBox[{"k", "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"p", " ", "\[Kappa]"}], "-", "\[CapitalLambda]"}], ")"}], " ", 
      SuperscriptBox[
       RowBox[{"a", "[", "t", "]"}], "2"]}], "+", 
     SuperscriptBox[
      RowBox[{
       SuperscriptBox["a", "\[Prime]",
        MultilineFunction->None], "[", "t", "]"}], "2"], "+", 
     RowBox[{"2", " ", 
      RowBox[{"a", "[", "t", "]"}], " ", 
      RowBox[{
       SuperscriptBox["a", "\[Prime]\[Prime]",
        MultilineFunction->None], "[", "t", "]"}]}]}], 
    RowBox[{
     RowBox[{"-", "1"}], "+", 
     RowBox[{"k", " ", 
      SuperscriptBox["r", "2"]}]}]], ",", 
   RowBox[{
    RowBox[{"-", 
     SuperscriptBox["r", "2"]}], " ", 
    RowBox[{"(", 
     RowBox[{"k", "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"p", " ", "\[Kappa]"}], "-", "\[CapitalLambda]"}], ")"}], 
       " ", 
       SuperscriptBox[
        RowBox[{"a", "[", "t", "]"}], "2"]}], "+", 
      SuperscriptBox[
       RowBox[{
        SuperscriptBox["a", "\[Prime]",
         MultilineFunction->None], "[", "t", "]"}], "2"], "+", 
      RowBox[{"2", " ", 
       RowBox[{"a", "[", "t", "]"}], " ", 
       RowBox[{
        SuperscriptBox["a", "\[Prime]\[Prime]",
         MultilineFunction->None], "[", "t", "]"}]}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"-", 
     SuperscriptBox["r", "2"]}], " ", 
    SuperscriptBox[
     RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], " ", 
    RowBox[{"(", 
     RowBox[{"k", "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"p", " ", "\[Kappa]"}], "-", "\[CapitalLambda]"}], ")"}], 
       " ", 
       SuperscriptBox[
        RowBox[{"a", "[", "t", "]"}], "2"]}], "+", 
      SuperscriptBox[
       RowBox[{
        SuperscriptBox["a", "\[Prime]",
         MultilineFunction->None], "[", "t", "]"}], "2"], "+", 
      RowBox[{"2", " ", 
       RowBox[{"a", "[", "t", "]"}], " ", 
       RowBox[{
        SuperscriptBox["a", "\[Prime]\[Prime]",
         MultilineFunction->None], "[", "t", "]"}]}]}], ")"}]}]}], 
  "}"}]], "Output",
 CellChangeTimes->{3.964562113823537*^9, 3.964562167427374*^9, 
  3.964569717644569*^9},
 CellLabel->"Out[38]="]
}, Open  ]],

Cell["Equating the LHS to zero gives the Friedmann equations:", "Text",
 CellChangeTimes->{{3.919769591991415*^9, 3.9197696177047424`*^9}, {
  3.9197702873278437`*^9, 3.9197702901690264`*^9}, {3.964562177518339*^9, 
  3.964562192998591*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Assuming", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"r", "!=", "0"}], " ", "&&", " ", 
     RowBox[{
      RowBox[{"a", "[", "t", "]"}], "!=", "0"}]}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"Zerodd", "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}], "==", "0"}], "//", 
     "FullSimplify"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"First", " ", "equation"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.9197692533313894`*^9, 3.919769262108313*^9}, {
  3.919769675137657*^9, 3.9197696938934045`*^9}, {3.919770292856125*^9, 
  3.9197702968894043`*^9}},
 CellLabel->"In[39]:="],

