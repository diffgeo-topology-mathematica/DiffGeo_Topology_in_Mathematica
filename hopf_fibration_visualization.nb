Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"soln", "[", 
    RowBox[{
     RowBox[{"x0_", "?", "NumericQ"}], ",", 
     RowBox[{"y0_", "?", "NumericQ"}], ",", 
     RowBox[{"z0_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"ux", "/", 
         RowBox[{"Abs", "[", "u", "]"}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"uy", "/", 
         RowBox[{"Abs", "[", "u", "]"}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"z", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"uz", "/", 
         RowBox[{"Abs", "[", "u", "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", "x0"}], ",", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], "==", "y0"}], ",", 
       RowBox[{
        RowBox[{"z", "[", "0", "]"}], "==", "z0"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "200"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.938563300786311*^9, 3.9385634508714724`*^9}, {
  3.9385637119244947`*^9, 3.9385637131921554`*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"1bcc4b45-d0ba-40e1-b225-b604869d3043"],

