Cell[BoxData[
 RowBox[{
  RowBox[{"Dnew", " ", "=", " ", 
   RowBox[{
    RowBox[{"R", "^", "2"}], " ", "+", " ", 
    RowBox[{
     RowBox[{"x", "[", "t", "]"}], "^", "2"}], " ", "+", " ", 
    RowBox[{
     RowBox[{"y", "[", "t", "]"}], "^", "2"}], " ", "+", " ", 
    RowBox[{
     RowBox[{"z", "[", "t", "]"}], "^", "2"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.938562816691263*^9, 3.9385628378220816`*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"8be6e502-997c-4828-b70e-fcac649a7d8b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ux", " ", "=", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"2", " ", "*", " ", 
      RowBox[{"A", "/", 
       RowBox[{"Dnew", "^", "2"}]}]}], ")"}], " ", "*", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "[", "t", "]"}], "*", 
       RowBox[{"z", "[", "t", "]"}]}], " ", "-", " ", 
      RowBox[{"R", "*", 
       RowBox[{"y", "[", "t", "]"}]}]}], ")"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.938562852647767*^9, 3.9385628557262783`*^9}, {
  3.9385629047382393`*^9, 3.9385629052347703`*^9}},
