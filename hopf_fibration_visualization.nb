Cell[BoxData[
 RowBox[{
  RowBox[{"uy", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"2", "*", 
      RowBox[{"A", "/", 
       RowBox[{"Dnew", "^", "2"}]}]}], ")"}], "*", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"R", "*", 
       RowBox[{"x", "[", "t", "]"}]}], "+", 
      RowBox[{
       RowBox[{"y", "[", "t", "]"}], "*", 
       RowBox[{"z", "[", "t", "]"}]}]}], ")"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.938562875172784*^9, 3.9385629089092293`*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"3265707b-f65b-46e3-941a-3cf027db0ef5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"uz", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", "2"}], ")"}], "*", 
    RowBox[{"(", 
     RowBox[{"A", "/", 
      RowBox[{"Dnew", "^", "2"}]}], ")"}], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"R", "^", "2"}], " ", "-", " ", 
      RowBox[{
       RowBox[{"x", "[", "t", "]"}], "^", "2"}], "-", 
      RowBox[{
       RowBox[{"y", "[", "t", "]"}], "^", "2"}], " ", "+", 
      RowBox[{
       RowBox[{"z", "[", "t", "]"}], "^", "2"}]}], ")"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9385628983358736`*^9, 3.938562942749031*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"32d1bdbf-0e27-4480-a438-c453a5bd4b3b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"u", "=", 
   RowBox[{"Sqrt", "[", 
